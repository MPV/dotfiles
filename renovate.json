{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "git-submodules": {
    "enabled": true
  },
  "dependencyDashboard": true,
  "prConcurrentLimit": 60,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.plugin-versions$/"
      ],
      "matchStrings": [
        "(?<depName>\\S+)(?<indentation>\\s*)(?<packageName>https:\\\/\\\/github.com\\\/[\\S]+)\\W*(?<currentValue>)(?<currentDigest>[a-f0-9]{7,40})"
      ],
      "autoReplaceStringTemplate": "{{{depName}}}{{indentation}}{{{packageName}}} {{{newDigest}}}",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "git"
    }
  ],
  "ignoreTests": true,
  "packageRules": [
    {
      "description": [
        "Combine the two representations of each asdf plugin (git submodule +",
        ".plugin-versions digest) into a single branch so they upgrade together,",
        "then merge straight to the branch without opening a PR."
      ],
      "matchManagers": ["git-submodules"],
      "matchDepNames": [".asdf/plugins/*"],
      "groupName": "asdf plugins",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": [
        "Same group as the submodule digests, so the .plugin-versions digest for",
        "each plugin lands in the same branch/commit instead of a separate one."
      ],
      "matchFileNames": [".plugin-versions"],
      "groupName": "asdf plugins",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": [
        "Automerge ASDF versions of tools (minor & patch)",
        "as I prefer to upgrade major versions myself",
        "but should be fine to use latest otherwise"
      ],
      "matchManagers": ["asdf"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": [
        "Do not automerge ASDF versions of these tools (minor)",
        "as I prefer to upgrade minor version myself of these"
      ],
      "matchManagers": ["asdf"],
      "matchUpdateTypes": ["minor"],
      "matchDepNames": [
        "argocd",
        "vault",
        "kubectl"
      ],
      "automerge": false
    }
  ]
}
